# CLIProxyAPI — bate com cliproxyapi/config.yaml (host 127.0.0.1, port 8318, api-key onepiece-proxy-key)
ANTHROPIC_PROXY_URL=http://127.0.0.1:8318
ANTHROPIC_PROXY_KEY=onepiece-proxy-key

# Modelos (IDs como o CLIProxyAPI expõe). Full Sonnet 5 em todos os papéis.
NARRATOR_MODEL=claude-sonnet-5
AGENT_MODEL=claude-sonnet-5
CRYSTALLIZER_MODEL=claude-sonnet-5
DIRECTOR_MODEL=claude-sonnet-5
# Sonnet 5 rejeita temperature (400); o proxy client não a envia p/ esse modelo.
AGENT_TEMPERATURE=0.7

# Caminhos (vazio = default: data/campaign.db dentro de backend/; prompts em ../prompts)
OPRPG_DB_PATH=
OPRPG_PROMPTS_DIR=
OPRPG_FRONTEND_DIST=
